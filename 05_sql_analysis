    "query5 = \"\"\"\n",
    "SELECT\n",
    "    Year,\n",
    "    CASE\n",
    "        WHEN [Month Number] BETWEEN 1 AND 3 THEN 'Q1'\n",
    "        WHEN [Month Number] BETWEEN 4 AND 6 THEN 'Q2'\n",
    "        WHEN [Month Number] BETWEEN 7 AND 9 THEN 'Q3'\n",
    "        ELSE 'Q4'\n",
    "    END                              AS Quarter,\n",
    "    ROUND(SUM(Sales), 2)             AS Quarterly_Sales,\n",
    "    ROUND(SUM(Profit), 2)            AS Quarterly_Profit,\n",
    "    ROUND(SUM(Profit) * 100.0 /\n",
    "          SUM(Sales), 2)             AS Profit_Margin_Pct,\n",
    "    SUM([Units Sold])                AS Total_Units\n",
    "FROM financial_data\n",
    "GROUP BY Year, Quarter\n",
    "ORDER BY Year, Quarter\n",
    "\"\"\"\n",
