    "def rolling_forecast(data, col, window=3, growth=1.02):\n",
    "    \"\"\"\n",
    "    Forecast using weighted moving average of last N months\n",
    "    growth = assumed growth rate per period\n",
    "    \"\"\"\n",
    "    forecasts = []\n",
    "    values = data[col].values\n",
    "\n",
    "    for i in range(len(values)):\n",
    "        if i < window:\n",
    "            # Not enough history — use available data\n",
    "            forecast = values[:i+1].mean() * growth\n",
    "        else:\n",
    "            # Weighted average — more recent months get higher weight\n",
    "            weights = np.array([0.5, 0.3, 0.2])  # most recent first\n",
    "            recent = values[i-window+1:i+1][::-1]\n",
    "            forecast = np.dot(recent[:len(weights)], weights[:len(recent)]) * growth\n",
    "        forecasts.append(round(forecast, 2))\n",
    "\n",
    "    return forecasts\n",
    "\n",
    "# Apply forecast to Sales and Profit\n",
    "monthly_actuals['Forecast_Sales_Base'] = rolling_forecast(\n",
    "    monthly_actuals, 'Actual_Sales', window=3, growth=1.02)\n",
    "monthly_actuals['Forecast_Sales_Conservative'] = rolling_forecast(\n",
    "    monthly_actuals, 'Actual_Sales', window=3, growth=0.98)\n",
    "monthly_actuals['Forecast_Profit_Base'] = rolling_forecast(\n",
    "    monthly_actuals, 'Actual_Profit', window=3, growth=1.02)\n",
    "\n",
    "print(\"✅ Rolling forecasts calculated!\")\n",
    "print(monthly_actuals[[\n",
    "    'Period', 'Actual_Sales',\n",
    "    'Forecast_Sales_Base', 'Forecast_Sales_Conservative'\n",
    "]].tail(8).to_string(index=False))"
