   "source": [
    "# Variance Analysis — Gross Sales vs Actual Sales (Discount Impact)\n",
    "df['Discount_Variance'] = df['Gross Sales'] - df['Sales']\n",
    "df['Discount_Impact_Pct'] = round((df['Discount_Variance'] / df['Gross Sales']) * 100, 2)\n",
    "df['Profit_Margin_Pct'] = round((df['Profit'] / df['Sales']) * 100, 2)\n",
    "\n",
    "# Segment level variance summary\n",
    "variance_summary = df.groupby('Segment').agg(\n",
    "    Gross_Sales=('Gross Sales', 'sum'),\n",
    "    Net_Sales=('Sales', 'sum'),\n",
    "    Total_Discounts=('Discounts', 'sum'),\n",
    "    Total_COGS=('COGS', 'sum'),\n",
    "    Total_Profit=('Profit', 'sum'),\n",
    "    Units_Sold=('Units Sold', 'sum')\n",
    ").round(2).reset_index()\n",
    "\n",
    "variance_summary['Discount_Impact_Pct'] = round(\n",
    "    variance_summary['Total_Discounts'] / variance_summary['Gross_Sales'] * 100, 2)\n",
    "variance_summary['Profit_Margin_Pct'] = round(\n",
    "    variance_summary['Total_Profit'] / variance_summary['Net_Sales'] * 100, 2)\n",
    "variance_summary['Revenue_Leakage'] = (\n",
    "    variance_summary['Gross_Sales'] - variance_summary['Net_Sales']).round(2)\n",
    "\n",
    "print(\"📊 FP&A Variance Summary by Segment:\")\n",
    "print(variance_summary[[\n",
    "    'Segment', 'Gross_Sales', 'Net_Sales',\n",
    "    'Revenue_Leakage', 'Discount_Impact_Pct',\n",
    "    'Total_Profit', 'Profit_Margin_Pct'\n",
    "]].to_string(index=False))"
