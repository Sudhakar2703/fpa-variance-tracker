    "def mape(actual, forecast):\n",
    "    \"\"\"Mean Absolute Percentage Error — standard FP&A forecast accuracy metric\"\"\"\n",
    "    actual = np.array(actual)\n",
    "    forecast = np.array(forecast)\n",
    "    mask = actual != 0\n",
    "    return round(np.mean(np.abs((actual[mask] - forecast[mask]) / actual[mask])) * 100, 2)\n",
    "\n",
    "base_mape = mape(monthly_actuals['Actual_Sales'],\n",
    "                 monthly_actuals['Forecast_Sales_Base'])\n",
