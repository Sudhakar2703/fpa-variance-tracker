    "    SUM([Units Sold]) AS Total_Units\n",
    "FROM financial_data\n",
    "GROUP BY Segment, Country\n",
    "ORDER BY Total_Profit DESC\n",
    "\"\"\"\n",
    "\n",
    "result = pd.read_sql_query(query, conn)\n",
