    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "running_total = 0\n",
    "bottoms = []\n",
    "\n",
    "for i, (cat, val) in enumerate(zip(categories, values)):\n",
    "    if i == 0:\n",
    "        ax.bar(cat, val/1e6, color=colors[i])\n",
    "        running_total = val\n",
    "    elif i == len(values)-1:\n",
    "        ax.bar(cat, profit/1e6, color=colors[i])\n",
    "    else:\n",
    "        running_total += val\n",
    "        ax.bar(cat, abs(val)/1e6,\n",
    "               bottom=running_total/1e6 if val < 0 else running_total/1e6,\n",
    "               color=colors[i])\n",
    "        if val < 0:\n",
    "            running_total += val\n",
