    "print(f\"   Base Case forecast error:         {base_mape}%\")\n",
    "print(f\"   Conservative forecast error:      {cons_mape}%\")\n",
    "print(f\"\\n   Industry benchmark: <10% is considered good FP&A forecast accuracy\")"
